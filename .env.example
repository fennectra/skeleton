# ── Application ─────────────────────────────────────────
APP_ENV=dev
APP_NAME="My API"
APP_DESCRIPTION="REST API built with Fennectra"
APP_VERSION=1.0.0
APP_URL=http://localhost:8080

# ── Documentation ───────────────────────────────────────
# Docs are enabled automatically when APP_ENV=dev
# Set DOCS_ENABLED=true to enable in production
#DOCS_ENABLED=false

# Custom prefix for docs routes (default: /docs)
#DOCS_PREFIX=/docs

# Auth token endpoint shown in Scalar/OpenAPI docs
#AUTH_TOKEN_URL=/auth/login

# ── Database ────────────────────────────────────────────
# Driver: pgsql | mysql | sqlite
DB_DRIVER=sqlite

# PostgreSQL
#POSTGRES_HOST=localhost
#POSTGRES_PORT=5432
#POSTGRES_DB=my_api
#POSTGRES_USER=
#POSTGRES_PASSWORD=

# MySQL
#MYSQL_HOST=localhost
#MYSQL_PORT=3306
#MYSQL_DB=my_api
#MYSQL_USER=
#MYSQL_PASSWORD=

# SQLite
SQLITE_DB=var/database.sqlite

# ── Authentication ──────────────────────────────────────
# JWT secret key (base64, minimum 32 bytes)
# Generate: php -r "echo base64_encode(random_bytes(32));"
SECRET_KEY=

# JWT Token TTL (seconds)
#JWT_ACCESS_TTL=900              # 15 minutes (default)
#JWT_REFRESH_TTL=86400           # 24 hours (default)

# ── Events ──────────────────────────────────────────────
# Broker: sync | redis | database
EVENT_BROKER=sync

# ── Redis (required if EVENT_BROKER=redis) ──────────────
#REDIS_HOST=127.0.0.1
#REDIS_PORT=6379
#REDIS_PASSWORD=
#REDIS_DB=0
#REDIS_PREFIX=app:

# ── Storage ─────────────────────────────────────────────
# Driver: local | s3 | gcs
STORAGE_DRIVER=local

# S3 (required if STORAGE_DRIVER=s3)
#S3_KEY=
#S3_SECRET=
#S3_REGION=eu-west-3
#S3_BUCKET=
#S3_ENDPOINT=
#S3_PREFIX=

# GCS (required if STORAGE_DRIVER=gcs)
#GCS_BUCKET=
#GCS_PROJECT=
#GCS_KEY_FILE=
#GCS_PREFIX=

# ── Security ────────────────────────────────────────────
# Encryption at rest (AES-256-GCM, 32 bytes base64)
#ENCRYPTION_KEY=

# CORS whitelist (comma-separated)
#CORS_ALLOWED_ORIGINS=https://app.example.com

# Password policy
#PASSWORD_MIN_LENGTH=12

# Account lockout
#LOCKOUT_MAX_ATTEMPTS=5
#LOCKOUT_DURATION=900

# IP allowlist for admin routes (CIDR)
#IP_ALLOWLIST=127.0.0.1

# ── Multi-tenancy (optional) ────────────────────────────
#POSTGRES_TENANT_CLIENT1_HOST=localhost
#POSTGRES_TENANT_CLIENT1_PORT=5432
#POSTGRES_TENANT_CLIENT1_DB=client1_db
#POSTGRES_TENANT_CLIENT1_USER=
#POSTGRES_TENANT_CLIENT1_PASSWORD=

# ── Compliance ──────────────────────────────────────────
# NF525 SIREN
#NF525_SIREN=000000000

# Audit log retention (days)
#AUDIT_RETENTION_DAYS=365

# ── FrankenPHP Worker ───────────────────────────────────
# Max requests before worker restart
MAX_REQUESTS=500

# ── Profiler ────────────────────────────────────────────
#PROFILER_ENABLED=1

# ── Admin Dashboard (UI) ─────────────────────────────────
# Super admin emails (comma-separated)
#UI_ADMIN_EMAIL=admin@example.com
#UI_ADMIN_PASSWORD=

# ── Email (SMTP) ─────────────────────────────────────────
#MAIL_HOST=smtp.example.com
#MAIL_PORT=587
#MAIL_USERNAME=
#MAIL_PASSWORD=
#MAIL_FROM_ADDRESS=noreply@example.com
#MAIL_FROM_NAME="${APP_NAME}"
