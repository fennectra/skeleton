#EVENT BROKER (sync | redis | database)
EVENT_BROKER=redis

#REDIS (requis si EVENT_BROKER=redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
#REDIS_PASSWORD=
REDIS_DB=15
REDIS_PREFIX=app:events:

#EVENT DATABASE (requis si EVENT_BROKER=database)
#EVENT_DB_CONNECTION=default
#EVENT_DB_TABLE=events

#STORAGE (local | s3 | gcs)
STORAGE_DRIVER=local
#APP_URL=https://php.futurandco.tv

#S3 (requis si STORAGE_DRIVER=s3)
#S3_KEY=
#S3_SECRET=
#S3_REGION=eu-west-3
#S3_BUCKET=
#S3_ENDPOINT=
#S3_PREFIX=
#S3_URL=

#GCS (requis si STORAGE_DRIVER=gcs)
#GCS_BUCKET="ia-generation-5.appspot.com"
#GCS_PROJECT=
#GCS_KEY_FILE=                  # optionnel si Workload Identity (K8s)
#GCS_PREFIX=
#GCS_URL=https://storage.googleapis.com/ia-generation-5.appspot.com/users/1                       # CDN custom (optionnel, defaut: https://storage.googleapis.com/BUCKET)

# ── Multi-tenancy (optionnel) ──────────────────────────
# Credentials DB pour chaque tenant (voir app/config/tenants.php)
# POSTGRES_TENANT_CLIENT1_HOST=localhost
# POSTGRES_TENANT_CLIENT1_PORT=5432
# POSTGRES_TENANT_CLIENT1_DB=client1_db
# POSTGRES_TENANT_CLIENT1_USER=client1_user
# POSTGRES_TENANT_CLIENT1_PASSWORD=secret

# ── SOC 2 — Security & Compliance ────────────────────
# JWT Token TTL (secondes)
#JWT_ACCESS_TTL=900              # 15 minutes (defaut)
#JWT_REFRESH_TTL=86400           # 24 heures (defaut)

# Encryption at rest (AES-256-GCM, 32 bytes base64)
# Generer avec: php -r "echo base64_encode(random_bytes(32));"
#ENCRYPTION_KEY=

# CORS whitelist (comma-separated, requis en prod)
#CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Log masking — cles supplementaires a masquer (optionnel)
#LOG_MASK_FIELDS=custom_field,other_secret

# ── ISO 27001 — Access Controls ─────────────────────
# Password policy (longueur minimum)
#PASSWORD_MIN_LENGTH=12              # defaut: 12

# Account lockout (apres N echecs)
#LOCKOUT_MAX_ATTEMPTS=5              # defaut: 5
#LOCKOUT_DURATION=900                # defaut: 900s (15 min)

# IP allowlist pour routes admin (comma-separated, CIDR supporte)
#IP_ALLOWLIST=10.0.0.0/8,192.168.1.0/24,127.0.0.1

# Audit log retention (jours, pour audit:purge)
#AUDIT_RETENTION_DAYS=365            # defaut: 365

# ── NF525 — Facturation certifiee ────────────────────
# SIREN pour le nom du fichier FEC
#NF525_SIREN=000000000

# ── Fennec UI Dashboard ──────────────────────────────
# Emails des super admins autorises (comma-separated)
#UI_ADMIN_EMAIL=admin@example.com,superadmin@example.com
#UI_ADMIN_PASSWORD=

# Methode 1 : activation explicite
# PROFILER_ENABLED=1

# Methode 2 : automatique en mode developpement
APP_ENV=dev

# limite le nombre de requetes qu'un worker traite avant de redemarrer
MAX_REQUESTS=500    # Redemarrer le worker apres 500 requetes