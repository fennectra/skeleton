{
    "name": "fennectra/skeleton",
    "description": "Fennectra — Squelette d'application API",
    "type": "project",
    "license": "MIT",
    "keywords": ["php", "framework", "api", "fennectra"],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2",
        "fennectra/framework": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "scripts": {
        "serve": "php -S 0.0.0.0:8080 -t public",
        "quality": "php vendor/bin/fennec quality",
        "test": "php vendor/bin/phpunit",
        "lint": "php vendor/bin/php-cs-fixer check app/ --rules=@PSR12",
        "lint:fix": "php vendor/bin/php-cs-fixer fix app/ --rules=@PSR12"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
