{
    "name": "fennectra/skeleton",
    "description": "Fennectra — Squelette d'application API",
    "type": "project",
    "license": "MIT",
    "keywords": ["php", "framework", "api", "fennectra"],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2",
        "fennectra/framework": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "serve": "php -S 0.0.0.0:8080 -t public",
        "quality": "./forge quality"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
